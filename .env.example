# UWANGKU Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# PocketBase URL Configuration
# ============================================
# Android Emulator (default) - connects to host machine localhost
PB_BASE_URL=http://10.0.2.2:8090

# Device Fisik - ganti dengan IP laptop kamu:
# Cara cek IP: ipconfig (Windows) | hostname -I (WSL/Linux)
# Contoh: PB_BASE_URL=http://192.168.1.100:8090

# Production server:
# PB_BASE_URL=https://api.uwangku.com

# ============================================
# Groq API Key (for AI chat and receipt scanning)
# ============================================
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (optional, for additional AI features)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here